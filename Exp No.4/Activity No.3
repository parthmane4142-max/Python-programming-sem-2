# Program to reverse a customer feedback message

feedback = input("Enter customer feedback: ")

# Reverse the string
reversed_feedback = feedback[::-1]

print("\n--- Result ---")
print("Original Feedback:", feedback)
print("Reversed Feedback:", reversed_feedback)
